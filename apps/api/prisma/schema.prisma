generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuditAction {
  LOGIN
  CONNECTION_CREATED
  SCHEMA_REFRESHED
  QUERY_EXECUTED
  QUERY_SAVED
  DASHBOARD_CARD_CREATED
}

/// External analytics DB (not the app Prisma DB). Extend enum + add adapter when supporting new engines.
enum ExternalDbProvider {
  postgres
  mysql
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  connections DatabaseConnection[]
  savedQueries SavedQuery[]
  dashboards  Dashboard[]
  auditLogs   AuditLog[]
  settings    WorkspaceSettings?
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs AuditLog[]
  settings  UserSettings?
}

model UserSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  theme       String   @default("system")
  locale      String   @default("en-US")
  density     String   @default("comfortable")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkspaceSettings {
  id                          String              @id @default(cuid())
  organizationId              String              @unique
  organization                Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timezone                    String              @default("UTC")
  defaultDatabaseConnectionId String?
  defaultDatabaseConnection   DatabaseConnection? @relation("DefaultWorkspaceConnection", fields: [defaultDatabaseConnectionId], references: [id], onDelete: SetNull)
  defaultQueryRowLimit        Int                 @default(100)
  defaultSchemaContextMode    String              @default("selected_tables")
  showSqlByDefault            Boolean             @default(true)
  showExplanationByDefault    Boolean             @default(true)
  autoRunGeneratedSql         Boolean             @default(false)
  autoChart                   Boolean             @default(true)
  defaultChartType            String              @default("auto")
  kpiFirst                    Boolean             @default(true)
  chartCollapsedByDefault     Boolean             @default(false)
  chartDensity                String              @default("comfortable")
  clarificationMode           String              @default("ask_when_unsure")
  lowConfidenceWarning        Boolean             @default(true)
  preferredLlmProvider        String              @default("automatic")
  preferredLlmModel           String?
  notifications               Json                @default("{\"anomalyAlerts\":true,\"scheduledReports\":true,\"dashboardRefresh\":false,\"inApp\":true,\"email\":false}")
  dashboardDefaults           Json                @default("{\"defaultLayout\":\"balanced\",\"refreshInterval\":\"manual\"}")
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

model DatabaseConnection {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  databaseType     ExternalDbProvider @default(postgres)
  /// Legacy URI form (seed / old API). Prefer structured fields + `password`; execution uses builder when set.
  connectionString String   @default("")
  host             String?
  port             Int?
  databaseName     String?
  username         String?
  /// MVP plaintext; replace via `ConnectionCredentialsStore` pattern — never expose in API responses or logs.
  password         String?
  ssl              Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schemas        DatabaseSchema[]
  savedQueries   SavedQuery[]
  queryRuns      QueryRun[]
  dashboardCards DashboardCard[]
  defaultForWorkspaceSettings WorkspaceSettings[] @relation("DefaultWorkspaceConnection")

  @@index([organizationId])
}

model DatabaseSchema {
  id           String   @id @default(cuid())
  connectionId String
  connection   DatabaseConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  fetchedAt    DateTime @default(now())
  schemaJson   Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([connectionId])
}

model SavedQuery {
  id                      String   @id @default(cuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectionId            String
  connection              DatabaseConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  title                   String
  sqlText                 String
  /// SQL as first produced by the assistant (before user edits), when applicable.
  generatedSqlText        String?
  naturalLanguageQuestion String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  runs QueryRun[]

  @@index([organizationId])
  @@index([connectionId])
}

model QueryRun {
  id           String    @id @default(cuid())
  savedQueryId String?
  savedQuery   SavedQuery? @relation(fields: [savedQueryId], references: [id], onDelete: SetNull)
  connectionId String
  connection   DatabaseConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sqlText      String
  /// Question that led to this run (Ask flow), when provided at execution time.
  naturalLanguageQuestion String?
  rowCount     Int?
  success      Boolean
  errorMessage String?
  durationMs   Int?
  createdAt    DateTime  @default(now())

  @@index([connectionId])
}

model Dashboard {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cards DashboardCard[]

  @@index([organizationId])
}

model DashboardCard {
  id           String   @id @default(cuid())
  dashboardId  String
  dashboard    Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  connectionId String
  connection   DatabaseConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  title        String
  chartType    String
  sqlText      String
  /// react-grid-layout x (columns), 0-based.
  layoutX      Int      @default(0)
  /// react-grid-layout y (rows), 0-based.
  layoutY      Int      @default(0)
  /// Width in grid columns (dashboard uses 12 columns).
  layoutW      Int      @default(6)
  /// Height in grid row units.
  layoutH      Int      @default(6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dashboardId])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         AuditAction
  resourceType   String?
  resourceId     String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([organizationId])
}
