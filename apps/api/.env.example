DATABASE_URL="postgresql://copilot:copilot@localhost:5432/copilot_app?schema=public"
JWT_SECRET="change-me-in-development-use-a-long-random-string-at-least-32-chars"
CREDENTIAL_ENCRYPTION_KEY="change-me-in-development-use-a-long-random-string-at-least-32-chars"
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# LLM SQL generation (POST /queries/generate-sql). Primary then fallback on errors / invalid SQL.
# SQL_GEN_PRIMARY_PROVIDER=gemini
# SQL_GEN_FALLBACK_PROVIDER=groq
# SQL_GEN_TIMEOUT_MS=55000
# SQL_GEN_MIN_CONFIDENCE_SCORE=0.45
# SQL_GEN_PROMPT_MAX_TABLES=36
# SQL_GEN_PROMPT_MAX_COLS_PER_TABLE=48
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# MySQL SSL verification (defaults to true; set false only for local dev with self-signed certs)
# MYSQL_SSL_REJECT_UNAUTHORIZED=false
