# Copy to apps/api/.env and apps/web/.env.local as needed (see README).

# App database (PostgreSQL via Docker Compose)
DATABASE_URL="postgresql://copilot:copilot@localhost:5432/copilot_app?schema=public"

# Redis (optional for future caching / sessions)
REDIS_URL="redis://localhost:6379"

# API (NestJS)
JWT_SECRET="change-me-in-development-use-long-random-string"
API_PORT=4000
NODE_ENV=development

# Frontend — browser must reach API (use full URL)
NEXT_PUBLIC_API_URL="http://localhost:4000"
