# Copy to apps/api/.env and apps/web/.env.local as needed (see README).

# App database (PostgreSQL via Docker Compose)
DATABASE_URL="postgresql://copilot:copilot@localhost:5432/copilot_app?schema=public"

# API (NestJS)
JWT_SECRET="change-me-in-development-use-a-long-random-string-at-least-32-chars"
CREDENTIAL_ENCRYPTION_KEY="change-me-in-development-use-a-long-random-string-at-least-32-chars"
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Frontend — browser must reach API (use full URL)
NEXT_PUBLIC_API_URL="http://localhost:4000"
